{
  "productName": "SCPF Desktop",
  "version": "0.1.0",
  "identifier": "com.teycir.scpf.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:frontend-only -- --host 0.0.0.0",
    "beforeBuildCommand": "npm run build && npm run build:desktop:backend",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SCPF Desktop - Smart Contract Pattern Finder",
        "width": 1500,
        "height": 960,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 1180,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Desktop workspace for Smart Contract Pattern Finder",
    "longDescription": "A Tauri desktop workspace for scanning smart contracts with the local SCPF engine.",
    "resources": [
      "resources/bin",
      "resources/config",
      "resources/templates"
    ]
  }
}
